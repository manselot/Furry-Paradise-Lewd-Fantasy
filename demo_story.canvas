{
	"nodes":[
		{"id":"b1af345bbb06a0d5","type":"text","text":"Черт, стипендия  еще не пришла так что купить я смогу мало чего . так что возьму только самое необходимое ","x":1330,"y":-3912,"width":291,"height":135},
		{"id":"58137acd532ab3f6","type":"text","text":"лапша","x":1710,"y":-3611,"width":250,"height":60},
		{"id":"5f980ed0aa36d4dc","type":"text","text":"Потом возьму все остальное","x":172,"y":-2887,"width":250,"height":60},
		{"id":"93f3cbf12e04edae","type":"text","text":"лапша","x":287,"y":-3103,"width":250,"height":60},
		{"id":"cc8bd90f4017b277","type":"text","text":"С Кортни","x":297,"y":-3897,"width":250,"height":60,"color":"1"},
		{"id":"1b112ea979aa79f8","type":"text","text":"Черт и куда она ушла? Ладно, потом найду","x":65,"y":-3751,"width":260,"height":79},
		{"id":"1cd6e04c769f2392","type":"text","text":"ЛОКАЦИЯ МАГАЗИН","x":780,"y":-3897,"width":250,"height":60,"color":"4"},
		{"id":"48a28f77cc0f8044","type":"text","text":"Один","x":1129,"y":-3887,"width":134,"height":50},
		{"id":"cb71f0e8c798a499","type":"text","text":"Черт, стипендия  еще не пришла так что купить я смогу мало чего . так что возьму только самое необходимое ","x":-81,"y":-3318,"width":291,"height":135},
		{"id":"1940b9777b28830d","type":"text","text":"пиво","x":-393,"y":-3103,"width":250,"height":60},
		{"id":"28ee36bdb7aa4cbb","type":"text","text":"Пару баночек освежающего пиво никогда не повредят","x":-446,"y":-2944,"width":303,"height":98},
		{"id":"5e99be46ad10ad83","type":"text","text":"И где же она?\n*Немного походя по магазину я ее наконец нашел","x":-94,"y":-2612,"width":292,"height":103},
		{"id":"8582b7ad153d4201","type":"text","text":"Отдел с орехами и прочей хуйней","x":-712,"y":-2534,"width":319,"height":50,"color":"4"},
		{"id":"7088830467f702a3","type":"text","text":"О, вот ты где!","x":-73,"y":-2412,"width":250,"height":60},
		{"id":"f2b54d058004c45d","type":"text","text":"А? Да-да, погоди минуту","x":-74,"y":-2241,"width":250,"height":60,"color":"1"},
		{"id":"7d6596936266b678","type":"text","text":"*Она выбирала так товары словно от этого зависит хоть что-то*\nнаконец взяв все мы отправились уже на кассу","x":-75,"y":-2132,"width":252,"height":160},
		{"id":"ed69d59f3a618812","type":"text","text":"А ты чего себе взял?","x":-75,"y":-1842,"width":250,"height":60,"color":"1"},
		{"id":"df2cc2250946e23c","type":"text","text":"Почему бы и нет","x":575,"y":-1450,"width":195,"height":58},
		{"id":"242e6b08bb77d4fe","type":"text","text":"Чудно. Тогда пошли в парк, нам никто не помешает","x":547,"y":-1278,"width":238,"height":84,"color":"1"},
		{"id":"b45c4ad8c97e3850","type":"text","text":"Добравшись до общаги я увидел следующею картину","x":62,"y":1320,"width":258,"height":92},
		{"id":"608873df04d3ea20","type":"text","text":"А хорошо здесь, никто не беспокоит, никого, мне этим место и нравиться","x":-2335,"y":-332,"width":257,"height":98,"color":"1"},
		{"id":"e7cbadaa66e2f42b","type":"text","text":"За встречу","x":-976,"y":-112,"width":250,"height":60},
		{"id":"397dc99a6892439a","type":"text","text":"За что пьем?","x":-940,"y":-332,"width":178,"height":60},
		{"id":"7e27d490a142210c","type":"text","text":"Чтобы никто не ебал мозги","x":-618,"y":-112,"width":250,"height":60},
		{"id":"3b5ca842c12d9452","type":"text","text":"Чудную компанию","x":-1310,"y":-112,"width":250,"height":60},
		{"id":"880028d9fa8c63d2","type":"text","text":"За встречу","x":-975,"y":14,"width":250,"height":60,"color":"1"},
		{"id":"3f5d716181658681","type":"text","text":"Парк","x":-2115,"y":-582,"width":250,"height":60,"color":"4"},
		{"id":"c368d2d0d1eac437","type":"text","text":"","x":-2435,"y":939,"width":250,"height":60},
		{"id":"acc435f0ff869901","type":"text","text":"*имя*\nПриятно познакомиться\nМне тоже. еще раз прости, пойду поищу свою комнату","x":1355,"y":-10052,"width":280,"height":165,"color":"#000000"},
		{"id":"a809e44b56525c7b","type":"text","text":"Прости, но я сильно устал. Давай не сегодня \nЭмм, ладно\n**уходит*","x":1666,"y":-10052,"width":329,"height":165,"color":"#000000"},
		{"id":"9516a38078c416eb","type":"text","text":"Что? Ладно, видимо уже сам не свой.","x":1020,"y":-9620,"width":250,"height":60},
		{"id":"b26d33d7a30086be","type":"text","text":"Что??","x":485,"y":-8352,"width":250,"height":60},
		{"id":"2b936244bdb724d5","type":"text","text":"*В этот же момент чувствую удар по моему достоинству","x":485,"y":-8212,"width":250,"height":80,"color":"1"},
		{"id":"d7e829278c312e7a","type":"text","text":"Блять...","x":485,"y":-8072,"width":250,"height":50},
		{"id":"fa4a8226bd0157f6","type":"text","text":"Ой, это не ты, а где тогда тот мудила и кто ты?","x":485,"y":-7892,"width":250,"height":60},
		{"id":"6a6f4289ca9eaae9","type":"text","text":"Блять...","x":485,"y":-7766,"width":250,"height":60},
		{"id":"5e28a4bee65ae998","type":"text","text":"Блять...","x":205,"y":-7766,"width":250,"height":60},
		{"id":"38737e35b4230896","type":"text","text":"Блять...","x":797,"y":-7766,"width":250,"height":60},
		{"id":"51adf6ad66bc1c0c","type":"text","text":"А, ну да, подыши пока. А вот и ты мудила","x":485,"y":-7552,"width":250,"height":60,"color":"1"},
		{"id":"7d632c89f547f26b","type":"text","text":"Еще раз, возьмешь мою еду, то сделаю из тебя неудачную версию Франкинштейна ТЫ МЕНЯ ПОНЯЛ?","x":446,"y":-7354,"width":328,"height":122,"color":"#f90606"},
		{"id":"83f4e6db18a48866","type":"text","text":"Воу тише-тише, я же не знал, что это твое. ","x":485,"y":-7157,"width":250,"height":60,"color":"5"},
		{"id":"77689d08b96c5bd6","type":"text","text":"Да ты совсем вижу недалекий кусок говна, *удар*, с тобой я еще не закончила.","x":465,"y":-7032,"width":291,"height":100,"color":"1"},
		{"id":"b2523195adf4c2a7","type":"text","text":"Что касается тебя!...прости, не думала, что тут будет кто-то другой. Новенький?","x":485,"y":-6861,"width":250,"height":109,"color":"1"},
		{"id":"bf5b4fb9534db494","type":"text","text":"Ты в себя поверил?","x":820,"y":-6292,"width":250,"height":60,"color":"1"},
		{"id":"220d7d4f9c9f2d50","type":"text","text":"Я так-то и рассердиться могу, ответь, будь так добр","x":877,"y":-6108,"width":250,"height":60,"color":"1"},
		{"id":"ed72a6f2d828dad9","type":"text","text":"Послать","x":820,"y":-6485,"width":250,"height":60},
		{"id":"352ec2e0d41d364d","type":"text","text":"Да. Ты всех так приветствуешь?","x":206,"y":-6404,"width":237,"height":60},
		{"id":"12863c3dcdee31e9","type":"text","text":"Послать ЕЩЕ раз","x":878,"y":-5979,"width":250,"height":60},
		{"id":"cd055b66df5cb235","type":"text","text":"Как же вы меня бесите...","x":878,"y":-5854,"width":250,"height":60,"color":"1"},
		{"id":"9a4a59a1dce046f2","type":"text","text":"*Удар*","x":878,"y":-5706,"width":250,"height":60,"color":"1"},
		{"id":"8d2e927e75d21a0b","type":"text","text":"В этот момент он что-то спрашивал, но удар был слишком сильным и его просто не слушал","x":2047,"y":-4424,"width":327,"height":111},
		{"id":"44bf542304b8a50b","type":"text","text":"Немного придя в себя, я отправился в магазин","x":2085,"y":-4249,"width":250,"height":60},
		{"id":"d6849cea6a717ede","type":"text","text":"Мои шары","x":1128,"y":-5195,"width":250,"height":60},
		{"id":"214646f740114e36","type":"text","text":"*уходит, как ни в чем не бывало*","x":1185,"y":-5435,"width":250,"height":60},
		{"id":"a39cf82b9461f211","type":"text","text":"Ты в порядке? Не хило тебя так","x":1355,"y":-5315,"width":250,"height":60,"color":"5"},
		{"id":"bc2707b870d45859","type":"text","text":"Отвали","x":1591,"y":-5190,"width":250,"height":60},
		{"id":"ec9106bf08637e97","type":"text","text":"Это была случайность. Давай помогу.","x":200,"y":-6262,"width":250,"height":60,"color":"1"},
		{"id":"250a31a8939fb12b","type":"text","text":"*удар*","x":196,"y":-5903,"width":250,"height":60,"color":"1"},
		{"id":"161f7a1d58414df0","type":"text","text":"С ознакомительной частью закончили. Я Кортни кстати, а ты?","x":200,"y":-5756,"width":243,"height":100,"color":"1"},
		{"id":"a744023d6793195b","type":"text","text":"Еще бы. Я не позволю всяким забирать ее лишь потому, что они захотели есть. Не моя проблема. Найди работу, ты бездарный гитарист , не получиться у тебя ничего, найти работу.","x":322,"y":-5359,"width":226,"height":242,"color":"1"},
		{"id":"54b57054c0359968","type":"text","text":"*user*","x":606,"y":-5550,"width":250,"height":60},
		{"id":"0e266940490a6211","type":"text","text":"м-мм","x":310,"y":-5055,"width":250,"height":60,"color":"5"},
		{"id":"a9bf5d7c64383694","type":"text","text":"Не лучшее знакомство, понимаю, предлагаю прогуляться, с меня закуска с тебя пиво. И свежий воздух тебе не повредит. Отказ не принимаю","x":310,"y":-4890,"width":250,"height":198,"color":"1"},
		{"id":"bf0b344dccf75aba","type":"text","text":"не хочу узнавать что будет в случае отказа","x":310,"y":-4634,"width":250,"height":60},
		{"id":"0c718ef58a37d991","type":"text","text":"Мудрое решение. Ну пошли.\n*протягивает руку*","x":311,"y":-4512,"width":249,"height":88,"color":"1"},
		{"id":"69eb49100f4b0781","type":"text","text":"у меня есть идея . давай так, я тебя угощаю, за твои муки идет ?","x":590,"y":-1645,"width":294,"height":102,"color":"1"},
		{"id":"db2838cdfeaf3010","type":"text","text":"Такой застолье пропускает. Давай за стол","x":245,"y":4178,"width":257,"height":88,"color":"3"},
		{"id":"cff793af7a5d4ee9","type":"text","text":"Из напитков, у нас только, виски, медовуха и вино. Что будешь?","x":245,"y":4320,"width":254,"height":105,"color":"3"},
		{"id":"04e4f2cc385bdaa6","type":"text","text":"Виски я что-то должен?","x":-63,"y":4800,"width":250,"height":60},
		{"id":"7375e6a9f6af128f","type":"text","text":"Медовуха, я что-то должен?","x":250,"y":4800,"width":250,"height":60},
		{"id":"b42f19efde0bf084","type":"text","text":"Вино, я что-то должен?","x":594,"y":4800,"width":250,"height":60},
		{"id":"3c0a6f9b7b39e2cc","type":"text","text":"Неожиданный выбор, держи.","x":594,"y":4960,"width":250,"height":50,"color":"3"},
		{"id":"1986f36b649f711e","type":"text","text":"Хорошо.","x":251,"y":4952,"width":250,"height":60,"color":"3"},
		{"id":"df350358681d2341","type":"text","text":"Наш амино","x":-63,"y":4944,"width":250,"height":60,"color":"3"},
		{"id":"4ea15cde0f6116d1","type":"text","text":"А все это считайте подарком, от мох друзей","x":251,"y":5120,"width":250,"height":98,"color":"3"},
		{"id":"871501214673da95","type":"text","text":"Друзей? на вид отморозки полные, таким доверять себе дороже.","x":253,"y":5311,"width":247,"height":89,"color":"2"},
		{"id":"517f07dbe2a42eb3","type":"text","text":"Возможно, но и лишних вопросов я не задаю, как и не спрашиваю тебя зачем тебе гримуар, ведь так?\nХоть это было и не так просто достать. Но смею предположить, что ты хочешь, а именно вызвать Асмодея и получать удовольствие до последнего вздоха, ведь так?","x":253,"y":5440,"width":249,"height":347,"color":"3"},
		{"id":"b41857dad74caa3b","type":"text","text":"Не думал, что будет хоть какой-то выбор,  А буду я...","x":235,"y":4600,"width":274,"height":106},
		{"id":"f6df409c90617b80","type":"text","text":"Выпить.","x":238,"y":6715,"width":250,"height":60},
		{"id":"604487049390a9a4","type":"text","text":"Да же так?","x":207,"y":7553,"width":250,"height":60},
		{"id":"93715ebebc52581f","type":"text","text":"Да, там нет меня.  А вообще мужчин здесь не так и много, я даже удивлена, что здесь вас сразу трое и еще человечек с нами","x":208,"y":7651,"width":251,"height":145,"color":"6"},
		{"id":"844e24d6ee9f0081","type":"text","text":"*еще выпили*","x":215,"y":8062,"width":250,"height":60},
		{"id":"16db85e90bbc806e","type":"text","text":"А у тебя есть кто? Не то что мне сильно принципиально, но...","x":216,"y":8189,"width":250,"height":113,"color":"6"},
		{"id":"61bb384904b5eee5","type":"text","text":"Сам не знаю","x":-137,"y":8367,"width":250,"height":60},
		{"id":"a64aef5b39daec35","type":"text","text":"Многозначительный ответ, меня устраивает ","x":-137,"y":8533,"width":250,"height":60,"color":"6"},
		{"id":"802a7ddc68c0fe45","type":"text","text":"Я присматриваюсь","x":643,"y":8371,"width":250,"height":60},
		{"id":"0463b97a5d4c03cf","type":"text","text":"Нет","x":216,"y":8377,"width":250,"height":60},
		{"id":"101606d7b62a9ead","type":"text","text":"Смотри осторожнее, не всегда что ты видишь на первый взгляд, кажется, то чем является","x":643,"y":8567,"width":277,"height":131,"color":"6"},
		{"id":"5501ab407e08c266","type":"text","text":"Оно и к лучшему, что никого нет сейчас, а то знаешь, все эти ранние залеты, браки по расчету, бедность и что потом? В передачу, где всякие неудачники себя показывают, себя, с пузом на камеру. И сами еще как дети. Я думаю надо пожить, а потом уже думать над этим вопросом","x":216,"y":8533,"width":250,"height":329,"color":"6"},
		{"id":"356180077302763c","type":"text","text":"Полный отстой","x":717,"y":7237,"width":250,"height":60},
		{"id":"7327d595012f2be9","type":"text","text":"Не так плохо, как кажется на первый взгляд","x":208,"y":7252,"width":250,"height":60},
		{"id":"d1d75dbf537c167c","type":"text","text":"Это еще что, тебе считай повезло, в других блоках еще хуже","x":207,"y":7371,"width":251,"height":109,"color":"6"},
		{"id":"a59f003e883403dc","type":"text","text":"На первый взгляд может и так, могла и быть хуже","x":717,"y":7401,"width":250,"height":60,"color":"6"},
		{"id":"23344684000b9098","type":"text","text":"А тут хорошо","x":-137,"y":7245,"width":250,"height":60},
		{"id":"8286e2002eb28a6f","type":"text","text":"А будет еще лушче","x":-137,"y":7371,"width":250,"height":60,"color":"6"},
		{"id":"dd6c3b074dc9b17d","type":"text","text":"Ну чего малыш, как тебе здесь","x":207,"y":7080,"width":250,"height":60,"color":"6"},
		{"id":"d6f99f3de15be17e","type":"text","text":"Это я тебе обещаю","x":-137,"y":7553,"width":250,"height":60,"color":"6"},
		{"id":"38c0694c348346e4","type":"text","text":"Начинает чуть темнеть в круг экран","x":1060,"y":6880,"width":250,"height":60,"color":"4"},
		{"id":"096f5279f6917b00","type":"text","text":"Даааа, вид не важный. Видишь, до чего довел меня, нехер воровать мою еду","x":200,"y":-6108,"width":243,"height":129,"color":"1"},
		{"id":"2363f801a9b212ce","type":"text","text":"ЧТО? НЕТ, как ты могла вообще об этом подумать?","x":253,"y":5840,"width":250,"height":60,"color":"2"},
		{"id":"507046d364d961bb","type":"text","text":"Один из владельцев такой же книги, решил его призвать, не знаю получил он чего желал, но он покинул этот мир, точно счастливым","x":253,"y":5960,"width":251,"height":200,"color":"3"},
		{"id":"3dea64529da38393","type":"text","text":"Мерзость...","x":254,"y":6200,"width":250,"height":60,"color":"2"},
		{"id":"36f148d6b6c6cacb","type":"text","text":"*молчание*","x":254,"y":6317,"width":250,"height":60,"color":"5"},
		{"id":"775fd061abe81fb5","type":"text","text":"А, вот и ты мудила. С пасхой тебя","x":485,"y":-8602,"width":250,"height":60,"color":"1"},
		{"id":"7a650e29cb23a1d9","type":"text","text":"Мутный он какой-то","x":1706,"y":-9645,"width":250,"height":55},
		{"id":"19bb3ebda5e8acf9","type":"text","text":"Убежала по своим делам","x":372,"y":4031,"width":250,"height":60},
		{"id":"99e006627f60d41e","type":"text","text":"Предлагаю выпить за успех","x":216,"y":7920,"width":250,"height":60,"color":"3"},
		{"id":"84fa372728d4d2d1","type":"text","text":"Просто будь с ней аккуратна","x":238,"y":6910,"width":250,"height":60,"color":"3"},
		{"id":"bd7994a353153d62","type":"text","text":"Не по мне, жутко, надо выпить","x":780,"y":6655,"width":250,"height":60},
		{"id":"7c444774984561ef","type":"text","text":"Вполне неплохая идея, но пожалуй мне надо выпить.","x":-262,"y":6655,"width":250,"height":60},
		{"id":"d44939c623bf0c05","type":"text","text":"Общий холл","x":-1339,"y":3693,"width":250,"height":60,"color":"4"},
		{"id":"2f1addc36822ffbe","type":"text","text":"Я ей не нянька","x":-488,"y":4066,"width":250,"height":50},
		{"id":"cf88ffe1b9f1d360","type":"text","text":"Кстати, а где кортни?","x":-108,"y":3898,"width":250,"height":60,"color":"3"},
		{"id":"5382b66d3e30be7f","type":"text","text":"Я не знаю","x":-88,"y":4066,"width":250,"height":60},
		{"id":"d5d143e631f2ddb2","type":"text","text":"Вот и ты *user*, правильно понимаю? Присоединяйся, к нашему застолью, я Стейси","x":77,"y":3693,"width":295,"height":86,"color":"3"},
		{"id":"8ad990cd919f05a0","type":"text","text":"О, тут все что-ли собрались? И все уже сидят пьют","x":90,"y":3555,"width":270,"height":91},
		{"id":"ddb7844ad66d137a","type":"text","text":"Вот как...","x":-1475,"y":2443,"width":250,"height":60,"color":"1"},
		{"id":"ed6a364cb1e1623d","type":"text","text":"Уход","x":-1475,"y":2554,"width":250,"height":60},
		{"id":"046dc1697e31c2a0","type":"text","text":"qte","x":-1031,"y":2614,"width":250,"height":60},
		{"id":"a30c35a96f9b6cea","type":"text","text":"Удиви меня","x":-1031,"y":2738,"width":250,"height":60,"color":"1"},
		{"id":"305d41ab92bdede1","type":"text","text":"Рандом старик","x":-1725,"y":2855,"width":250,"height":60,"color":"4"},
		{"id":"10560a40988990a8","type":"text","text":"Вам не стыдно, это парк, а не ночной клуб","x":-1032,"y":2855,"width":250,"height":60,"color":"#fa0092"},
		{"id":"a0cf24c599fb4abb","type":"text","text":"Иди ты нахуй старая клуша, по тебе могила плачет\n*ушла*","x":-1033,"y":2958,"width":251,"height":80,"color":"1"},
		{"id":"9764c3d3743cef3d","type":"text","text":"А тебе что особое приглашение нужно?","x":-1032,"y":3078,"width":250,"height":60,"color":"#cd189d"},
		{"id":"6541df9399a879a9","type":"text","text":"*Поцелуй*","x":-906,"y":2126,"width":257,"height":60},
		{"id":"36ea35a4ece1d474","type":"text","text":"*Приближение* Нас же заметят","x":-527,"y":2156,"width":250,"height":90},
		{"id":"09d24d3c7f590e01","type":"text","text":"Мне это не интересно","x":-1707,"y":2199,"width":250,"height":60},
		{"id":"d4dd47f266d99b87","type":"text","text":"Я не могу","x":-1225,"y":2270,"width":250,"height":60},
		{"id":"5fd3c04702850f16","type":"text","text":"В этом все и дело, я так периодически пар сбрасываю. Так что, это даже меня заводит","x":-527,"y":2300,"width":250,"height":106,"color":"1"},
		{"id":"6c63974c4f113a76","type":"text","text":"Приблизиться","x":-750,"y":2473,"width":250,"height":60},
		{"id":"e2bbb2d028a98f10","type":"text","text":"У меня есть идея, как скрасить этот день, для Нас.","x":-902,"y":1366,"width":257,"height":86,"color":"1"},
		{"id":"2447c6e2488fc91d","type":"text","text":"Ты меня заинтриговала","x":-1195,"y":1574,"width":250,"height":60},
		{"id":"99127c80450f85f9","type":"text","text":"Чтобы ты не придумала, мне это не нравиться","x":-583,"y":1574,"width":250,"height":60},
		{"id":"accecb94096f21ca","type":"text","text":"Возможно. Закрой глаза","x":-910,"y":1760,"width":250,"height":60,"color":"1"},
		{"id":"949d7ecb6757adb0","type":"text","text":"Удар был на 5 баллов, мне даже немного понравилось","x":-1457,"y":683,"width":266,"height":85},
		{"id":"80d12ffd655e90be","type":"text","text":"Расскажешь?","x":-1002,"y":683,"width":250,"height":60},
		{"id":"d679733fcfeda255","type":"text","text":"И что же? Тот факт, что до них хоть кто-то кроме тебя дотронулся?","x":-1452,"y":808,"width":257,"height":114,"color":"1"},
		{"id":"d42a8dc2f23a8b40","type":"text","text":"Потом как-нибудь","x":-1000,"y":831,"width":250,"height":60,"color":"1"},
		{"id":"ef0f268c16dae426","type":"text","text":"...","x":-1449,"y":948,"width":250,"height":60},
		{"id":"3469caf298ed3fba","type":"text","text":"Однако, мне искренне жаль что вышло именно так и вот все думаю как загладить вину...","x":-908,"y":1093,"width":266,"height":113,"color":"1"},
		{"id":"59c33324e7c1281c","type":"text","text":"Слушай, прости за удар, сама не своя, просто все достало, много навалилось. ","x":-1023,"y":438,"width":291,"height":80},
		{"id":"a7c4ee528f6decc2","type":"text","text":"И ты решила выместить всю злость?","x":-587,"y":660,"width":250,"height":60},
		{"id":"e8266d7e01a328c6","type":"text","text":"Не самый плохой вариант скажу я тебе. Не ходишь потом как невротик","x":-587,"y":824,"width":250,"height":98,"color":"1"},
		{"id":"4f8c0f99ba354572","type":"text","text":"Еще одно слово и я вызову полицию, уж они дадут тебе всего что ты пожелаешь","x":-560,"y":3280,"width":280,"height":100,"color":"#f500ed"},
		{"id":"fb5220fd9cf01c93","type":"text","text":"Не желаешь занять ее место","x":-781,"y":3168,"width":250,"height":60},
		{"id":"0f7592ae36f9d36d","type":"text","text":"Уже ухожу","x":-1400,"y":3300,"width":250,"height":60},
		{"id":"43b641d65b6daa3c","type":"text","text":"Что это вообще все было?","x":-977,"y":3490,"width":250,"height":60},
		{"id":"3c150612ed457076","type":"text","text":"*Хват*","x":-1350,"y":1960,"width":250,"height":60},
		{"id":"4869e19073e4fd73","type":"text","text":"Не самый бедный ассортимент тут","x":520,"y":-8856,"width":250,"height":60},
		{"id":"7c29f78b0d6aec6b","type":"text","text":"Подлет к холодильнику","x":1128,"y":-8856,"width":250,"height":60,"color":"4"},
		{"id":"b475c28678a7e126","type":"text","text":"Комната гг","x":620,"y":-11010,"width":250,"height":60,"color":"4"},
		{"id":"b3a63df902d8c7f1","type":"text","text":"*уход*","x":1248,"y":-11648,"width":250,"height":60},
		{"id":"e6e9e475331b4c1c","type":"text","text":"Общий холл","x":645,"y":-11310,"width":250,"height":60,"color":"4"},
		{"id":"9800f60f0a51b17d","type":"text","text":"Вот твоя комната, если будут какие-то вопросы, задавай, а живу вот здесь, соседи, как и с *Gwen* и...минуту\n*звонок* Что?Ладно, сейчас буду.\nПрости но появились дела, до вечера, не скучай","x":1368,"y":-11157,"width":310,"height":200,"color":"2"},
		{"id":"2701b260dd7bcff4","type":"text","text":"Это общий холл. Здесь все что может тебе понадобиться, душевая вот там","x":1339,"y":-11388,"width":293,"height":138,"color":"2"},
		{"id":"ebbb048118b256d1","type":"text","text":"Голова...сама падает к ним, а мой друг...","x":-4550,"y":11448,"width":250,"height":90},
		{"id":"d79493e32f0a1870","type":"text","text":"","x":-4190,"y":11463,"width":250,"height":60},
		{"id":"28b27fd4e629b543","type":"text","text":"Комната ","x":-4175,"y":12384,"width":250,"height":60,"color":"4"},
		{"id":"db64abb53b40082d","type":"text","text":"Последний глоток","x":-4875,"y":10880,"width":250,"height":60},
		{"id":"86769c1ea7238242","type":"text","text":"Ушли все","x":-5280,"y":11130,"width":250,"height":60},
		{"id":"c00b5f03578a93b5","type":"text","text":"Пошли со мной.","x":-5280,"y":11240,"width":250,"height":60},
		{"id":"7ceeaddf23a71260","type":"text","text":"*я и слова связать не могу*","x":-5280,"y":11388,"width":250,"height":60},
		{"id":"3d73c3f4e886061e","type":"text","text":"Не беспокойся, к утру будешь как новенький, легкий галлюциноген собственного производства доведенный до совершенства","x":-5280,"y":11510,"width":250,"height":180},
		{"id":"aed82328ed0e5370","type":"text","text":"Не будь столько категоричен, попробуй","x":-4585,"y":4435,"width":250,"height":60,"color":"6"},
		{"id":"0ffe8e540ac9a01e","type":"text","text":"Отказаться","x":-4836,"y":4621,"width":250,"height":60},
		{"id":"4a96a15814ad2bd7","type":"text","text":"Ладно, мое дело предложить...","x":-4835,"y":4738,"width":250,"height":60,"color":"6"},
		{"id":"146f553e43ef9680","type":"text","text":"Пролили медовуху на гг","x":-4556,"y":4835,"width":250,"height":60,"color":"4"},
		{"id":"9be39c5859c0839d","type":"text","text":"Я пожалуй пас","x":-4465,"y":4325,"width":250,"height":60},
		{"id":"69e99734796a1235","type":"text","text":"Уговорила","x":-4490,"y":4571,"width":250,"height":50},
		{"id":"c221fe30e8b60b9f","type":"text","text":"Что это?","x":-4181,"y":4075,"width":250,"height":60},
		{"id":"2d2a7a1aa84446c9","type":"text","text":"Сначала выпей, тебе понравиться","x":-4180,"y":4195,"width":250,"height":60,"color":"6"},
		{"id":"7365524705936c3d","type":"text","text":"Согласиться","x":-4181,"y":4325,"width":250,"height":60},
		{"id":"48a4a9dd9645c04d","type":"text","text":"*мм-м* вкусно, так и что это?","x":-4181,"y":4435,"width":250,"height":60},
		{"id":"a2a7f4912b1ab92b","type":"text","text":"Молоко...оно собственного производства","x":-4066,"y":4592,"width":250,"height":60},
		{"id":"c2aa33eda603e47e","type":"text","text":"Это великолепно, есть еще?","x":-4066,"y":4681,"width":250,"height":60},
		{"id":"07005e83760d5e89","type":"text","text":"Кстати, это для тебя, попробуй","x":-4181,"y":3975,"width":250,"height":60,"color":"6"},
		{"id":"22df936c929cc1f2","type":"text","text":"Ой прости пожалуйста, я не хотела","x":-4087,"y":4975,"width":250,"height":60,"color":"2"},
		{"id":"2b29966b4ed45099","type":"text","text":"Постираю и верну тебе как новенькую, отдавай, сейчас тебе принесу что-нибудь, не голым же тебе ходить","x":-3787,"y":5415,"width":270,"height":117,"color":"2"},
		{"id":"b8fa6b469d1cd0b9","type":"text","text":"А я и не против","x":-3777,"y":5590,"width":250,"height":60,"color":"6"},
		{"id":"50a6598fb5d6cdfd","type":"text","text":"*еще выпили*","x":-4110,"y":2917,"width":250,"height":60},
		{"id":"5738de7b88978064","type":"text","text":"А у тебя есть кто? Не то что мне сильно принципиально, но...","x":-4109,"y":3044,"width":250,"height":113,"color":"6"},
		{"id":"529e023b5e9c8da6","type":"text","text":"Сам не знаю","x":-4462,"y":3222,"width":250,"height":60},
		{"id":"ed62a73cca868869","type":"text","text":"Многозначительный ответ, меня устраивает ","x":-4462,"y":3388,"width":250,"height":60,"color":"6"},
		{"id":"e69dbb8dd9fa3961","type":"text","text":"Я присматриваюсь","x":-3682,"y":3226,"width":250,"height":60},
		{"id":"b9277ffb7582bd05","type":"text","text":"Нет","x":-4109,"y":3232,"width":250,"height":60},
		{"id":"75784cea897368c5","type":"text","text":"Смотри осторожнее, не всегда что ты видишь на первый взгляд, кажется, то чем является","x":-3682,"y":3422,"width":277,"height":131,"color":"6"},
		{"id":"619906b07f7d37f6","type":"text","text":"Оно и к лучшему, что никого нет сейчас, а то знаешь, все эти ранние залеты, браки по расчету, бедность и что потом? В передачу, где всякие неудачники себя показывают, себя, с пузом на камеру. И сами еще как дети. Я думаю надо пожить, а потом уже думать над этим вопросом","x":-4109,"y":3388,"width":250,"height":329,"color":"6"},
		{"id":"e69c74955f753a1b","type":"text","text":"Выпить","x":-3855,"y":5755,"width":250,"height":60},
		{"id":"b6fb493896113c11","type":"text","text":"Вернешь, но уже чистую","x":-3666,"y":5175,"width":250,"height":60},
		{"id":"9eb6d2dd88ebe8b9","type":"text","text":"Знаешь,каждое решение, принимаемое существом, может вести его в будущее или удерживать в прошлом, таким образом, существо свободно в определении направления своего выбора.","x":-5125,"y":5395,"width":290,"height":197,"color":"6"},
		{"id":"0fb71b59154480c9","type":"text","text":"И к чему это?","x":-5105,"y":5675,"width":250,"height":60},
		{"id":"57193d45ef3b7462","type":"text","text":"Не знаю, философ какой-то так писал, просто когда перепью люблю нести всякий берд. А может, что не всегда выбор и вправду решает хоть что-то","x":-5105,"y":5815,"width":250,"height":197,"color":"6"},
		{"id":"4ce4805d45222ec4","type":"text","text":"Оу, спасибо...он и вправду специально сделан для меня, я его сама сделала...","x":-5205,"y":6206,"width":269,"height":93,"color":"6"},
		{"id":"c87111bbd716ecf3","type":"text","text":"А для меня сделаешь?","x":-3587,"y":7075,"width":250,"height":60},
		{"id":"395e3bc0b3420354","type":"text","text":"Может быть сделаю, если будешь хорошим мальчиком","x":-3577,"y":7255,"width":240,"height":95,"color":"6"},
		{"id":"060e19690d4a0ba3","type":"text","text":"А это удобно","x":-3864,"y":7075,"width":250,"height":60},
		{"id":"9600a116b0df7dd4","type":"text","text":"Ахуеть","x":-4184,"y":7075,"width":250,"height":60},
		{"id":"f309546c775a3420","type":"text","text":"Слов не подобрать должных знаю, но очень удобно, не надо искать свой размер","x":-4184,"y":7281,"width":250,"height":105,"color":"6"},
		{"id":"fd99b857aed51d05","type":"text","text":"Еще бы","x":-3864,"y":7274,"width":250,"height":60,"color":"6"},
		{"id":"2c39a792f15f26eb","type":"text","text":"Ты даже после моих слов немного покраснел","x":-3863,"y":7475,"width":250,"height":60,"color":"6"},
		{"id":"a50e798eb2a12e44","type":"text","text":"*момент когда гг и всем стало хуже, перепили*","x":-4825,"y":7805,"width":375,"height":50,"color":"4"},
		{"id":"798004f60a5047ae","type":"text","text":"Испортила мою футболку...","x":-4240,"y":5164,"width":250,"height":60},
		{"id":"6462aa06b67f8b85","type":"text","text":"Выпить","x":-4936,"y":5194,"width":250,"height":60},
		{"id":"ed3573452f22c80d","type":"text","text":"Экран по окружности становиться чуть белым","x":-3125,"y":4708,"width":250,"height":60,"color":"4"},
		{"id":"f5d25307eb3f4eac","type":"text","text":"...из своей паутины","x":-3863,"y":6902,"width":250,"height":60,"color":"6"},
		{"id":"7234a0ed209b2edf","type":"text","text":"И к чему это?","x":-3864,"y":6206,"width":250,"height":60},
		{"id":"adae353bebbc6741","type":"text","text":"Не знаю, философ какой-то так писал, просто когда перепью люблю нести всякий берд. А может, что не всегда выбор и вправду решает исхода. А может я хотела сказать, что без футболки тебе даже лучше ","x":-3873,"y":6299,"width":259,"height":259,"color":"6"},
		{"id":"78118e2b9dbb6c5b","type":"text","text":"Оу, спасибо...он и вправду специально сделан для меня, я его сама сделала...","x":-3873,"y":6725,"width":269,"height":93,"color":"6"},
		{"id":"5b40c4822d55aefc","type":"text","text":"Знаешь,каждое решение, принимаемое существом, может вести его в будущее или удерживать в прошлом, таким образом, существо свободно в определении направления своего выбора.","x":-3883,"y":5914,"width":290,"height":197,"color":"6"},
		{"id":"2009ccbe5a090775","type":"text","text":"Охх, что-то мне не хорошо","x":-3863,"y":7615,"width":250,"height":60,"color":"#000000"},
		{"id":"5237df2ba81a5b03","type":"text","text":"Я знаю что поможет, дайте гитару, я сейчас спою","x":-3863,"y":7750,"width":250,"height":55,"color":"5"},
		{"id":"0413863bd71d2a02","type":"text","text":"Не порти пожалуйста этот день своим исполнением, если хочешь подарить радость нам, то помоги Юлию, а то вид у него совсем не важный, убираться после него не хватало. А своей игрой ты еще взвеешь  у нас всего неприятные эмоции в районе живота","x":-3890,"y":7875,"width":302,"height":260,"color":"3"},
		{"id":"e6062d7a4a0f0c34","type":"text","text":"Ладно...пойдем друг, подышим воздухом","x":-3864,"y":8215,"width":250,"height":60,"color":"5"},
		{"id":"0e1719a1d628f759","type":"text","text":"Веди","x":-3864,"y":8335,"width":250,"height":60,"color":"#000000"},
		{"id":"ad55334bb4005b6d","type":"text","text":"Неужели алкоголь плох? Уходим по одному...с вами конечно хорошо, но мне надо кое-что проверить. Не скучайте","x":-3877,"y":8452,"width":277,"height":163,"color":"3"},
		{"id":"011686d34fb1f819","type":"text","text":"Не знаю как ты, но я полна энтузиазма и чувствую себя, просто замечательно...как насчет того, чтобы закончить этот прекрасный день вместе?","x":-3871,"y":8695,"width":264,"height":178,"color":"6"},
		{"id":"15b33d8961eba8c7","type":"text","text":"Согласиться","x":-4118,"y":9055,"width":250,"height":60},
		{"id":"593f14cf0e723361","type":"text","text":"Отказаться ","x":-3566,"y":9055,"width":250,"height":60},
		{"id":"af696e8d8d2300cb","type":"text","text":"Мой ответ не доносится до нее...а голова стала ватной..не могу держать ее и она падает прямо к ней","x":-3864,"y":9245,"width":260,"height":119},
		{"id":"19442beb3f21ee1e","type":"text","text":"Предлагаю выпить за успех","x":-4109,"y":2775,"width":250,"height":60,"color":"3"},
		{"id":"b1589e866afb6d5c","type":"text","text":"Спасибо, кстати, классный свитер, как на тебя сшили ","x":-3864,"y":6615,"width":250,"height":60},
		{"id":"fc2eebe891ebe27f","type":"text","text":"Тише-тише не здесь, пошли со мной","x":-3861,"y":9435,"width":255,"height":105,"color":"6"},
		{"id":"abe5d35faf387e8a","type":"text","text":"А это что? Записка?","x":-3956,"y":10655,"width":250,"height":60},
		{"id":"13302b74cf9e13c6","type":"text","text":"Арка закончена","x":-3956,"y":10810,"width":250,"height":50},
		{"id":"40282e9e022f73a5","type":"text","text":"Утро","x":-4565,"y":10655,"width":250,"height":60,"color":"4"},
		{"id":"81f70da14425393e","type":"text","text":"О какой ты горячий, а тут что у нас. *звук ширинки**, О ты настолько рад меня видеть? Думаю одежда тебя сейчас лишь сковывает Иди сюда","x":-3861,"y":9735,"width":250,"height":210},
		{"id":"f3d552132ce3476d","type":"text","text":"qte","x":-3861,"y":10163,"width":250,"height":50},
		{"id":"028d336918912be5","type":"text","text":"Да и мне это вся одежка ни к чему. *снимает все*","x":-3861,"y":10025,"width":250,"height":80},
		{"id":"33f3a6c3453b8d02","type":"text","text":"Комнтата паука","x":-3316,"y":9735,"width":250,"height":60,"color":"4"},
		{"id":"55cfe30866498d5d","type":"text","text":"НУ ТУТ ТЕКСТ ПОТОМ, НУЖНО СДЕЛАТЬ СНАЧАЛО","x":-3985,"y":10315,"width":418,"height":108},
		{"id":"79cb2c9692f749e7","type":"text","text":"Поесть бы","x":1128,"y":-9460,"width":290,"height":182},
		{"id":"60e1e2e2e2cdbef9","type":"text","text":"Взять еду с холодильника\n","x":1319,"y":-9162,"width":250,"height":60},
		{"id":"ff94b18a7e7f66d3","type":"text","text":"Посмотрю насколько он набит там хоть и сразу в магазин","x":494,"y":-9094,"width":241,"height":94},
		{"id":"2fc84e691df76a85","type":"text","text":"Сходить в магазин","x":680,"y":-9222,"width":250,"height":60},
		{"id":"a9fff956723ccadb","type":"text","text":"Доброго дня дорогие абитуриенты. Вы здесь потому что прошли предварительное тестирование. А так же, как вы знаете, что с этого года в наш университет поступить могут и люди, и приятно удивлена, что некоторые смогли дойти до этого этапа, но если не получится, не переживайте, вы всегда может поступить в Орфурский университет. До поступления в наше замечательное заведение остается только одно. Экзаменационное сочинение, оно должно быть в 500 слов или меньше тема в этом году для вас: «Продемонстрируйте храбрость». Удачи.","x":185,"y":-18632,"width":368,"height":416},
		{"id":"c3747a21d898a12a","type":"text","text":"Как я вообще прошел до этого этапа...мне даже не сильно интересно вот это все. Ладно, продемонстрировать храбрость говорите, хорошо","x":237,"y":-18059,"width":266,"height":208},
		{"id":"31bc7641ad8aa0fd","type":"text","text":"*развернув лист поперек я написал*","x":245,"y":-17760,"width":250,"height":60},
		{"id":"1abbae5281caadd4","type":"text","text":"ПОСТУПАЙТЕ В ОРФУРСКИЙ ","x":245,"y":-17615,"width":250,"height":60},
		{"id":"333d6657c87dd0bd","type":"text","text":"Что будет, то будет, но если меня зачислят и после такого, то придется попробовать себя в этом амплуа ветеринара","x":245,"y":-17462,"width":250,"height":187},
		{"id":"d023eaf4c5728b8f","type":"text","text":"Препод","x":933,"y":-18495,"width":250,"height":60,"color":"4"},
		{"id":"0cbeafa7e20add5a","type":"text","text":" Однажды вопрос для экзаменационного сочинения в Гарвард звучал так: «В 500 словах или меньше продемонстрируйте храбрость». Один студент написал большими буквами поперек листа: «Поступайте в Йель!» Это основной конкурент Гарварда. Студент был зачислен.","x":-327,"y":-17700,"width":295,"height":303},
		{"id":"005279a2fcaf7bdb","type":"text","text":"Что тут у нас.\nИнтересно, сейчас посмотрю, чем могу помочь","x":-88,"y":-14205,"width":311,"height":91,"color":"6"},
		{"id":"e990e3f34d9440d1","type":"text","text":"Хочу показать, что и как у нас устроенно, я Eva, а ты?","x":102,"y":-13541,"width":250,"height":60,"color":"2"},
		{"id":"da2dcccf76271289","type":"text","text":"Поздравляю тебя, будешь жить в корпусе 69. Радуйся.","x":260,"y":-14055,"width":250,"height":90,"color":"6"},
		{"id":"36d41553ec737163","type":"text","text":"Иди ко мне. Посмотрим, что у тебя тут.","x":279,"y":-14190,"width":250,"height":60,"color":"6"},
		{"id":"afe406d4a0c8080b","type":"text","text":"А как иначе. Это корпус, где обитаю я...и она. ГОСПОДИ EVA, что тебе нужно!?","x":101,"y":-13725,"width":250,"height":125,"color":"6"},
		{"id":"5e1e2ab553ba4d4a","type":"text","text":"Ох бля","x":-380,"y":-15651,"width":250,"height":60},
		{"id":"4dcbca19bf682fef","type":"text","text":"Новенький","x":-55,"y":-15645,"width":250,"height":60},
		{"id":"78449ee4e4e89354","type":"text","text":"Ты чего застыл, куда направляешься. А это что? \n*схватила бумагу* Ага, ага. А, ну проходи второй этаж","x":-380,"y":-15521,"width":250,"height":136,"color":"#ff00dd"},
		{"id":"383ab7d79e0efa0b","type":"text","text":"Свежее мясо значит, проходи.","x":-55,"y":-15512,"width":250,"height":60,"color":"#ff0ff7"},
		{"id":"69b8288df5555e2d","type":"text","text":"...","x":-380,"y":-15321,"width":250,"height":60},
		{"id":"298a80fa154f344f","type":"text","text":"Куда?!","x":-54,"y":-15783,"width":250,"height":60,"color":"#ff00a2"},
		{"id":"dcb0a99c6e6dcc16","type":"text","text":"Не стой как дерево, проходи...первокурсники...","x":-380,"y":-15188,"width":250,"height":60,"color":"#fb00ff"},
		{"id":"1bc4e6b53c64890f","type":"text","text":"Моя хорошая, будь пожалуйста внимательнее, еще один косяк с твой стороны и я за себя не ручаюсь.","x":245,"y":-14868,"width":250,"height":183,"color":"6"},
		{"id":"7f1bb894335430c3","type":"text","text":"Прости","x":245,"y":-14645,"width":250,"height":60,"color":"2"},
		{"id":"c031e07008f709e2","type":"text","text":"Будь аккуратнее впредь. \nО здравствуй мой хороший, потерялся маленький?","x":245,"y":-14545,"width":242,"height":140,"color":"6"},
		{"id":"47771d80ee869efb","type":"text","text":"Протянуть пригласительный лист","x":-58,"y":-14324,"width":250,"height":60},
		{"id":"f938592db6f1012f","type":"text","text":"А вот и он","x":245,"y":-14988,"width":250,"height":60},
		{"id":"ad5288e1cea6af35","type":"text","text":"кабинет","x":925,"y":-14988,"width":250,"height":60,"color":"4"},
		{"id":"ae5791b9e49244f0","type":"text","text":"Что там было еще написано. «Для получение полной информации о внутренних правилах нашего университета, вам необходимо пройти в кабинет 2017». ","x":145,"y":-16186,"width":306,"height":160},
		{"id":"0289857030459204","type":"text","text":"Мб перед входом уника","x":960,"y":-16153,"width":250,"height":60,"color":"4"},
		{"id":"34f076e1e3f8ef9e","type":"text","text":"Стены уника","x":960,"y":-15752,"width":250,"height":60,"color":"4"},
		{"id":"aa9f693096a1428d","type":"text","text":"Консерж(стремный что пиздец)","x":960,"y":-15572,"width":250,"height":60,"color":"4"},
		{"id":"1f25198e25936181","type":"text","text":"Теперь можно и домой","x":245,"y":-17200,"width":250,"height":60},
		{"id":"25a981255e8cf966","type":"text","text":"Улица","x":680,"y":-17200,"width":250,"height":60,"color":"4"},
		{"id":"64264aab76594b91","type":"text","text":"Сколько писем. Счета, счета, реклама. О письмо","x":193,"y":-17028,"width":250,"height":60},
		{"id":"b4acc0867c61a36b","type":"text","text":"Спустя две недели. Дома","x":627,"y":-17028,"width":250,"height":60,"color":"4"},
		{"id":"f553cfc4bc7591db","type":"text","text":"Дорогой *user*,\n\nС радостью сообщаем новость: твоё заявление на поступление в университет было рассмотрено и успешно одобрено. Ты прошёл все этапы отбора и...","x":145,"y":-16865,"width":347,"height":200},
		{"id":"f2e1273c4ac90c47","type":"text","text":"Это либо какая-то шутка, либо у них проблема с отбором. Печать вроде настоящая.\nЛадно, мои родители хотели чтобы я стал кем-то, а тут хоть перспективы какие-то. ","x":180,"y":-16605,"width":278,"height":203},
		{"id":"1d13927c84c74afe","type":"text","text":"Тот кто скрасит серые будни в этих стенах. *user*","x":149,"y":-13359,"width":250,"height":66},
		{"id":"ff22d36728d5be32","type":"text","text":"Я на это надеюсь, что хоть этот год будет куда интереснее, чем прошлый","x":102,"y":-13168,"width":250,"height":110,"color":"2"},
		{"id":"ac962d0d04648c64","type":"text","text":"Рада знакомству.","x":-274,"y":-13143,"width":250,"height":60,"color":"2"},
		{"id":"ad82bc3b03490f77","type":"text","text":"уход\n","x":-148,"y":-12921,"width":250,"height":60},
		{"id":"ce03a4fca1a04930","type":"text","text":"Не так быстро, малыш. Давай, что тут у тебя","x":621,"y":-14216,"width":250,"height":60,"color":"6"},
		{"id":"efad9f7b59790231","type":"text","text":"Я кажется нашел, что искал, милашка","x":675,"y":-14354,"width":250,"height":60},
		{"id":"498c5819d51e0974","type":"text","text":"Другая поза","x":800,"y":-14545,"width":250,"height":60,"color":"4"},
		{"id":"f980879f936fb69e","type":"text","text":"Что?!... спасибо","x":7840,"y":-14077,"width":250,"height":60,"color":"2"},
		{"id":"ad214a06c159843f","type":"text","text":"Дорогуша, будь аккуратнее, я не посмотрю, что ты такая миленькая, да и работа у тебя еще есть","x":8181,"y":-13824,"width":285,"height":100,"color":"6"},
		{"id":"4e99e90e28373bfc","type":"text","text":"Ты чего так к нему пристала? А с работой, успею еще. Пошли, покажу твою комнату","x":8188,"y":-13664,"width":285,"height":80,"color":"2"},
		{"id":"6e619c008dee455f","type":"text","text":"Пойдем, покажу тебе комнату","x":8198,"y":-13914,"width":250,"height":50,"color":"2"},
		{"id":"e9b808440f991756","type":"text","text":"Рада знакомству","x":8448,"y":-14077,"width":250,"height":60,"color":"2"},
		{"id":"c39b90978d0b9496","type":"text","text":"Какие ушки","x":7840,"y":-14174,"width":250,"height":60},
		{"id":"2b671c84053147f6","type":"text","text":"Ой, подумаешь, ничего с ним не будет, ты посмотри на него","x":8120,"y":-14314,"width":288,"height":83,"color":"6"},
		{"id":"64a794a8aac1cf6e","type":"text","text":"Прекрати. Не пугай его раньше времени. Привет, я Ева, а ты?","x":8124,"y":-14474,"width":281,"height":90,"color":"2"},
		{"id":"aff434370e2f0a3b","type":"text","text":"Ну да, бывали тут холодные, а ты...такой теплый, аж...","x":8309,"y":-14892,"width":281,"height":120,"color":"6"},
		{"id":"39c2364ea5f8c698","type":"text","text":"Привет, я *user*","x":8448,"y":-14174,"width":250,"height":60},
		{"id":"f3be2c0fd2d388f2","type":"text","text":"По своей?","x":7840,"y":-15106,"width":250,"height":60},
		{"id":"bfbb23ce68a48c9e","type":"text","text":"Так вот ты какой, буду приглядывать за тобой. Впервые вижу человека. Поздравляю, считай ты первый, кто здесь находится...по своей воли","x":8181,"y":-15171,"width":338,"height":220,"color":"6"},
		{"id":"e467512fb6f6b600","type":"text","text":"Кадр ближе","x":8199,"y":-15406,"width":250,"height":60,"color":"4"},
		{"id":"9029fc587723e5e0","type":"text","text":"Сама значит уже прилипла к нему, а пристаю я, ну-ну","x":8206,"y":-13524,"width":250,"height":55,"color":"6"},
		{"id":"93acbbb85ca142a7","type":"text","text":"Концлагерь","x":5600,"y":-15781,"width":250,"height":60},
		{"id":"59add3fb66508122","type":"text","text":"Да, поможешь?","x":245,"y":-14324,"width":250,"height":60},
		{"id":"52f0362b818c69b1","type":"text","text":"И почему я должен радоваться?","x":10,"y":-13900,"width":250,"height":60},
		{"id":"460665df51b6778c","type":"text","text":"Промолчать","x":420,"y":-13900,"width":250,"height":60},
		{"id":"5f02118024fe50d7","type":"text","text":"*user*","x":-524,"y":-13460,"width":250,"height":60},
		{"id":"34e96d54d65ab521","type":"text","text":"Видимо ваш новый сосед. *user*","x":-200,"y":-13359,"width":250,"height":60},
		{"id":"39615958ecce723d","type":"text","text":"Давай помогу","x":1128,"y":-5085,"width":250,"height":60,"color":"5"},
		{"id":"e07e14c5836d2038","type":"text","text":"Не серчай","x":1605,"y":-5085,"width":250,"height":60,"color":"5"},
		{"id":"25e1f81ce879817d","type":"text","text":"Охх,блять...","x":1355,"y":-4900,"width":250,"height":60},
		{"id":"111ba2992d88e199","type":"text","text":"*user*. Ты так бьешь, только потому что кто-то взял еду?","x":-181,"y":-5630,"width":248,"height":80},
		{"id":"481b8710f34f9ab4","type":"text","text":"Выйдя из магазина, она с кем-то нервно разговарила по телефону","x":2480,"y":-3095,"width":287,"height":104},
		{"id":"bc16723b9dea4ef0","type":"text","text":"Встав в очередь, я заметил Кортни, она уже выходила с магазина","x":2362,"y":-3486,"width":262,"height":91},
		{"id":"19bc70a2505a3fe2","type":"text","text":"Пройти мимо","x":2880,"y":-2672,"width":250,"height":60},
		{"id":"9f8e4850a1ac30b9","type":"text","text":"Не, к ней я больше не подойду","x":3005,"y":-2241,"width":250,"height":55},
		{"id":"72452328ccefa3a1","type":"text","text":"Подойти к ней","x":2005,"y":-2827,"width":250,"height":60},
		{"id":"406ccc06f0e5c115","type":"text","text":"Заметив меня, она сказала в трубку. \n-Все, мне пора меня ждут","x":1960,"y":-2620,"width":252,"height":119,"color":"1"},
		{"id":"ec489ae5aae6d9b4","type":"text","text":"Чего хотел?","x":1897,"y":-2412,"width":250,"height":60,"color":"1"},
		{"id":"03be8bc10fc10706","type":"text","text":"Извинись!","x":2212,"y":-2316,"width":250,"height":60},
		{"id":"f6dfe2c5d4d88cc5","type":"text","text":"Охх, и кому ты решила испортить еще день?","x":1754,"y":-2160,"width":268,"height":84},
		{"id":"a942c8d0de01f852","type":"text","text":"С чего бы мне извиняться. М?","x":2197,"y":-2136,"width":280,"height":60,"color":"1"},
		{"id":"fc9a936348b847bc","type":"text","text":"а с того что ты ударила незнакомого  тебе человека которой не в чем не виноват и даже не удосужилась извиниться","x":2189,"y":-1922,"width":331,"height":102},
		{"id":"44d61c6762b91c79","type":"text","text":"пиво","x":700,"y":-3611,"width":250,"height":60},
		{"id":"b5f4f134b37032d9","type":"text","text":"Слушай, тебя это не касается. А это что у тебя?","x":1180,"y":-2076,"width":260,"height":97,"color":"1"},
		{"id":"75ead68d72bcf547","type":"text","text":"ну и что? ты что никогда не был незнакомца по яйцам?а это что у тебя?  ","x":1560,"y":-1780,"width":250,"height":88,"color":"1"},
		{"id":"f6e1e094f7a3ad1d","type":"text","text":"Пару баночек освежающего пиво никогда не повредят","x":826,"y":-3260,"width":303,"height":98},
		{"id":"d90cc6a3421d7ac4","type":"text","text":"Потом возьму все остальное","x":1460,"y":-3470,"width":250,"height":60},
		{"id":"2c90c85d976f2e35","type":"text","text":"Я пожалуй пас","x":940,"y":-1452,"width":250,"height":60},
		{"id":"089d9324a1eadff8","type":"text","text":"Метко бьешь","x":260,"y":-5550,"width":250,"height":60},
		{"id":"a53c39142faa25aa","type":"text","text":"Вот видишь! Никого ","x":-1435,"y":-582,"width":250,"height":60},
		{"id":"944dfeb6f6486965","type":"text","text":"Ну да, *вид спорта*, чуть-ли не с младенчества со мной одной дорогой идет. ","x":-2248,"y":-1072,"width":258,"height":114,"color":"1"},
		{"id":"9884a93e094fd4e0","type":"text","text":"Соревнований?","x":-2240,"y":-1254,"width":250,"height":60},
		{"id":"44622c6daee8927c","type":"text","text":"Надоели все! Пусть идут нахуй, чего они вообще взъелись, до соревнований еще куда времени","x":-2240,"y":-1484,"width":267,"height":113,"color":"1"},
		{"id":"a317b345c4c8ca85","type":"text","text":"Выйдя с магазина мы отправились в сторону парка\n*рингтон*, ой нахуй","x":-2293,"y":-1782,"width":373,"height":116},
		{"id":"de6e49087820ef8d","type":"text","text":"За легкую жизнь","x":-640,"y":14,"width":250,"height":60,"color":"1"},
		{"id":"4f71669cc3680288","type":"text","text":"А ты забавный","x":-1310,"y":14,"width":250,"height":60,"color":"1"},
		{"id":"c3ced896eac4a1e6","type":"text","text":"И какая же, одна из тех что обычно приходит в голову, но боишься сказать в слух?","x":-899,"y":1574,"width":257,"height":108},
		{"id":"bed76d90de0ffa3c","type":"text","text":"Я не кусаюсь","x":-527,"y":1798,"width":250,"height":60,"color":"1"},
		{"id":"2c5390f06ea2ef5d","type":"text","text":"Закрой глаза","x":-1260,"y":1730,"width":250,"height":60,"color":"1"},
		{"id":"84d454432e0dc304","type":"text","text":"Сладкая смерть. Что сам думаешь","x":254,"y":6520,"width":250,"height":60,"color":"6"},
		{"id":"b742b966f6247ac2","type":"text","text":"Лучше сожги ее, она не принесет тебе ничего хорошего","x":254,"y":6420,"width":250,"height":60,"color":"#000000"},
		{"id":"8b8bfbcb9248cd0c","type":"text","text":"Охх блять\n\n*комната-ну и хуйня\n\nСловно тут кто-то умер пару лет назад, а это что?\n\n*таракан пробегает по плинтусу\n\nБлеск\n\n*убил своей сумкой\n\nС этим тоже разберусь, а пока нужно отдохнуть\n\nЛадно хоть кровать хорошая, позже нужно будет обустроиться, что-то вроде говорили, что часть средств компенсируют.\n\n*не успев расслабиться ко мне кто-то стучится\n\n**Знакомство с готом\n\nО, привет, видимо ошибся комнатой. Меня зовут Юлий звать, а тебя?","x":1110,"y":-10745,"width":770,"height":573},
		{"id":"d1693e42a8afaa98","type":"text","text":"НУ ТУТ ТЕКСТ ПОТОМ, НУЖНО СДЕЛАТЬ СНАЧАЛО","x":-1372,"y":19940,"width":418,"height":108},
		{"id":"61803e1ca93f14d9","type":"text","text":"Утро","x":-1952,"y":20280,"width":250,"height":60,"color":"4"},
		{"id":"ea2f0e5fc0aa31ca","type":"text","text":"А это что? Записка?","x":-1343,"y":20280,"width":250,"height":60},
		{"id":"cf5decfe259788a6","type":"text","text":"Арка закончена","x":-1343,"y":20435,"width":250,"height":50},
		{"id":"8815b03519288cd4","type":"text","text":"Мой ответ не доносится до нее...а голова стала ватной..не могу держать ее и она падает прямо к ней","x":-1251,"y":18870,"width":260,"height":119},
		{"id":"28cc7b845cb8bf00","type":"text","text":"Тише-тише не здесь, пошли со мной","x":-1248,"y":19060,"width":255,"height":105,"color":"6"},
		{"id":"f13b3a4408a54455","type":"text","text":"О какой ты горячий, а тут что у нас. *звук ширинки**, О ты настолько рад меня видеть? Думаю одежда тебя сейчас лишь сковывает Иди сюда","x":-1248,"y":19360,"width":250,"height":210},
		{"id":"c1ac69fd5026c75d","type":"text","text":"Комнтата паука","x":-703,"y":19360,"width":250,"height":60,"color":"4"},
		{"id":"d4b89064c324f3e4","type":"text","text":"Да и мне это вся одежка ни к чему. *снимает все*","x":-1248,"y":19650,"width":250,"height":80},
		{"id":"f14ab28c552f15c1","type":"text","text":"qte","x":-1248,"y":19788,"width":250,"height":50},
		{"id":"065d1fb7c1ce7403","type":"text","text":"Веди","x":-1251,"y":17960,"width":250,"height":60,"color":"#000000"},
		{"id":"2288328e62cd8860","type":"text","text":"Неужели алкоголь плох? Уходим по одному...с вами конечно хорошо, но мне надо кое-что проверить. Не скучайте","x":-1264,"y":18077,"width":277,"height":163,"color":"3"},
		{"id":"e033df305d2fb505","type":"text","text":"Не знаю как ты, но я полна энтузиазма и чувствую себя, просто замечательно...как насчет того, чтобы закончить этот прекрасный день вместе?","x":-1258,"y":18320,"width":264,"height":178,"color":"6"},
		{"id":"7d7021160de0b4e5","type":"text","text":"Согласиться","x":-1505,"y":18680,"width":250,"height":60},
		{"id":"a830e98ddd5ffe26","type":"text","text":"Отказаться ","x":-953,"y":18680,"width":250,"height":60},
		{"id":"248492f1360b42db","type":"text","text":"Я знаю что поможет, дайте гитару, я сейчас спою","x":-1250,"y":17375,"width":250,"height":55,"color":"5"},
		{"id":"eba896bf073a0d6e","type":"text","text":"*момент когда гг и всем стало хуже, перепили*","x":-2212,"y":17430,"width":375,"height":50,"color":"4"},
		{"id":"6bd2cc698c03baf2","type":"text","text":"Не порти пожалуйста этот день своим исполнением, если хочешь подарить радость нам, то помоги Юлию, а то вид у него совсем не важный, убираться после него не хватало. А своей игрой ты еще взвеешь  у нас всего неприятные эмоции в районе живота","x":-1277,"y":17500,"width":302,"height":260,"color":"3"},
		{"id":"8a0e55c949a94741","type":"text","text":"Ладно...пойдем друг, подышим воздухом","x":-1251,"y":17840,"width":250,"height":60,"color":"5"},
		{"id":"83f30067b33d1729","type":"text","text":"Может быть сделаю, если будешь хорошим мальчиком","x":-964,"y":16880,"width":240,"height":95,"color":"6"},
		{"id":"0fb6cacb3bf9bbe3","type":"text","text":"Еще бы","x":-1251,"y":16899,"width":250,"height":60,"color":"6"},
		{"id":"09519d32d5a01f04","type":"text","text":"Слов не подобрать должных знаю, но очень удобно, не надо искать свой размер","x":-1571,"y":16906,"width":250,"height":105,"color":"6"},
		{"id":"e7ee96b49f1bfff0","type":"text","text":"Ты даже после моих слов немного покраснел","x":-1250,"y":17100,"width":250,"height":60,"color":"6"},
		{"id":"9cb52c6287640b94","type":"text","text":"Охх, что-то мне не хорошо","x":-1250,"y":17240,"width":250,"height":60,"color":"#000000"},
		{"id":"39112201c0275191","type":"text","text":"...из своей паутины","x":-1250,"y":16527,"width":250,"height":60,"color":"6"},
		{"id":"27ae34db6a287fa4","type":"text","text":"Ахуеть","x":-1571,"y":16700,"width":250,"height":60},
		{"id":"48fe42fd43efa63c","type":"text","text":"А это удобно","x":-1251,"y":16700,"width":250,"height":60},
		{"id":"280cd6ac7da0ab79","type":"text","text":"А для меня сделаешь?","x":-974,"y":16700,"width":250,"height":60},
		{"id":"adb2c8e2b1a4c6cd","type":"text","text":"Отказаться","x":-2223,"y":14246,"width":250,"height":60},
		{"id":"ac147f79e00dc197","type":"text","text":"Ладно, мое дело предложить...","x":-2222,"y":14363,"width":250,"height":60,"color":"6"},
		{"id":"454375d425d8067f","type":"text","text":"Не будь столько категоричен, попробуй","x":-1972,"y":14060,"width":250,"height":60,"color":"6"},
		{"id":"cdaff6d5e431574f","type":"text","text":"Пролили медовуху на гг","x":-1943,"y":14460,"width":250,"height":60,"color":"4"},
		{"id":"c4f1aef7fb9fa880","type":"text","text":"Уговорила","x":-1877,"y":14196,"width":250,"height":50},
		{"id":"7243d0fe9b8d497d","type":"text","text":"Я пожалуй пас","x":-1852,"y":13950,"width":250,"height":60},
		{"id":"f1910da4083fc038","type":"text","text":"Молоко...оно собственного производства","x":-1453,"y":14217,"width":250,"height":60},
		{"id":"b0b548837427b945","type":"text","text":"Это великолепно, есть еще?","x":-1453,"y":14306,"width":250,"height":60},
		{"id":"3d973248a7d34c29","type":"text","text":"Ой прости пожалуйста, я не хотела","x":-1474,"y":14600,"width":250,"height":60,"color":"2"},
		{"id":"d838f51c8d9a1d41","type":"text","text":"Вернешь, но уже чистую","x":-1053,"y":14800,"width":250,"height":60},
		{"id":"fa6768c4fb5688df","type":"text","text":"Испортила мою футболку...","x":-1627,"y":14789,"width":250,"height":60},
		{"id":"d871a26c6efc6688","type":"text","text":"Экран по окружности становиться чуть белым","x":-512,"y":14333,"width":250,"height":60,"color":"4"},
		{"id":"6b7204d94c7d46d7","type":"text","text":"Постираю и верну тебе как новенькую, отдавай, сейчас тебе принесу что-нибудь, не голым же тебе ходить","x":-1174,"y":15040,"width":270,"height":117,"color":"2"},
		{"id":"b1a1a8ba19a32cda","type":"text","text":"А я и не против","x":-1164,"y":15215,"width":250,"height":60,"color":"6"},
		{"id":"23d5d385daac415e","type":"text","text":"Выпить","x":-1242,"y":15380,"width":250,"height":60},
		{"id":"a9cf87ef33b5cded","type":"text","text":"И к чему это?","x":-1251,"y":15831,"width":250,"height":60},
		{"id":"89c18ba931aaae2c","type":"text","text":"Не знаю, философ какой-то так писал, просто когда перепью люблю нести всякий берд. А может, что не всегда выбор и вправду решает исхода. А может я хотела сказать, что без футболки тебе даже лучше ","x":-1260,"y":15924,"width":259,"height":259,"color":"6"},
		{"id":"b846c8fafbb4ca68","type":"text","text":"Оу, спасибо...он и вправду специально сделан для меня, я его сама сделала...","x":-1260,"y":16350,"width":269,"height":93,"color":"6"},
		{"id":"4f3497e8d0431338","type":"text","text":"Знаешь,каждое решение, принимаемое существом, может вести его в будущее или удерживать в прошлом, таким образом, существо свободно в определении направления своего выбора.","x":-1270,"y":15539,"width":290,"height":197,"color":"6"},
		{"id":"d688ccbcbae4fdba","type":"text","text":"Спасибо, кстати, классный свитер, как на тебя сшили ","x":-1251,"y":16240,"width":250,"height":60},
		{"id":"8a07f8882220e22a","type":"text","text":"Пусть так, кстати, классный свитер, как на тебя сшили ","x":-2972,"y":15848,"width":250,"height":60},
		{"id":"dafa238150db459b","type":"text","text":"Оу, спасибо...он и вправду специально сделан для меня, я его сама сделала...","x":-2592,"y":15831,"width":269,"height":93,"color":"6"},
		{"id":"0465c3d3c47067a0","type":"text","text":"Знаешь,каждое решение, принимаемое существом, может вести его в будущее или удерживать в прошлом, таким образом, существо свободно в определении направления своего выбора.","x":-2512,"y":15020,"width":290,"height":197,"color":"6"},
		{"id":"f7f2ece3492361a5","type":"text","text":"И к чему это?","x":-2492,"y":15300,"width":250,"height":60},
		{"id":"02afb60b087226ce","type":"text","text":"Не знаю, философ какой-то так писал, просто когда перепью люблю нести всякий берд. А может, что не всегда выбор и вправду решает хоть что-то","x":-2492,"y":15440,"width":250,"height":197,"color":"6"},
		{"id":"743f9a11df3085d1","type":"text","text":"Выпить","x":-2323,"y":14819,"width":250,"height":60},
		{"id":"4e1c6d46c2fe074c","type":"text","text":"Кстати, это для тебя, попробуй","x":-1568,"y":13600,"width":250,"height":60,"color":"6"},
		{"id":"52d26468f3dadee8","type":"text","text":"Что это?","x":-1568,"y":13700,"width":250,"height":60},
		{"id":"72023c0b84a6107a","type":"text","text":"Согласиться","x":-1568,"y":13950,"width":250,"height":60},
		{"id":"6d4b5f4d0db1caa5","type":"text","text":"*мм-м* вкусно, так и что это?","x":-1568,"y":14060,"width":250,"height":60},
		{"id":"9eb0a510ce7ab88f","type":"text","text":"Сначала выпей, тебе понравиться","x":-1567,"y":13820,"width":250,"height":60,"color":"6"}
	],
